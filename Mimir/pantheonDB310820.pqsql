--
-- Name: event; Type: TABLE; Schema: public; Owner: mimir
--

CREATE TABLE public.event (
    id integer NOT NULL,
    title character varying(255) NOT NULL,
    description text NOT NULL,
    start_time timestamp without time zone,
    end_time timestamp without time zone,
    game_duration integer,
    last_timer integer,
    red_zone integer,
    owner_formation integer,
    owner_player integer,
    type character varying(255) NOT NULL,
    stat_host character varying(255) NOT NULL,
    lobby_id integer,
    ruleset text NOT NULL,
    sync_start integer NOT NULL,
    auto_seating integer NOT NULL,
    sort_by_games integer NOT NULL,
    use_timer integer NOT NULL,
    allow_player_append integer NOT NULL,
    is_online integer NOT NULL,
    is_textlog integer NOT NULL,
    timezone character varying(255) NOT NULL,
    use_penalty integer NOT NULL,
    series_length integer DEFAULT 0 NOT NULL,
    hide_results integer DEFAULT 0 NOT NULL,
    games_status character varying(255),
    sync_end integer DEFAULT 0 NOT NULL,
    is_prescripted integer DEFAULT 0 NOT NULL,
    min_games_count integer DEFAULT 0 NOT NULL,
    is_team integer DEFAULT 0 NOT NULL
);


ALTER TABLE public.event OWNER TO mimir;

--
-- Name: COLUMN event.game_duration; Type: COMMENT; Schema: public; Owner: mimir
--

COMMENT ON COLUMN public.event.game_duration IS 'for timer, duration in seconds';


--
-- Name: COLUMN event.last_timer; Type: COMMENT; Schema: public; Owner: mimir
--

COMMENT ON COLUMN public.event.last_timer IS 'for timer, unix datetime of last started timer';


--
-- Name: COLUMN event.red_zone; Type: COMMENT; Schema: public; Owner: mimir
--

COMMENT ON COLUMN public.event.red_zone IS 'timer red zone amount in seconds, or null to disable red zone';


--
-- Name: COLUMN event.owner_formation; Type: COMMENT; Schema: public; Owner: mimir
--

COMMENT ON COLUMN public.event.owner_formation IS 'at least one owner id (user or formation) should be set!';


--
-- Name: COLUMN event.type; Type: COMMENT; Schema: public; Owner: mimir
--

COMMENT ON COLUMN public.event.type IS 'online or offline, tournament or local rating, interactive or simple';


--
-- Name: COLUMN event.stat_host; Type: COMMENT; Schema: public; Owner: mimir
--

