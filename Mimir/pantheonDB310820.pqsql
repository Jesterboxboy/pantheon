CREATE DATABASE frey WITH TEMPLATE = template0 OWNER = postgres;
GRANT ALL ON DATABASE frey TO frey;
CREATE DATABASE frey_unit WITH TEMPLATE = template0 OWNER = postgres;
GRANT ALL ON DATABASE frey_unit TO frey;
CREATE DATABASE mimir WITH TEMPLATE = template0 OWNER = postgres;
GRANT ALL ON DATABASE mimir TO mimir;
GRANT ALL ON DATABASE mimir TO michaeld;
CREATE DATABASE mimir_unit WITH TEMPLATE = template0 OWNER = postgres;
GRANT ALL ON DATABASE mimir_unit TO mimir;
GRANT ALL ON DATABASE mimir_unit TO michaeld;
